# Supabase – same project as back office (Railway).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Railway production: backoffice URL where /uploads/ and /objects/ are served.
# Store-front uses this to build full image URLs (backend URL + path). Required for
# deployed store-front; defaults to production backoffice if unset.
NEXT_PUBLIC_UPLOADS_BASE_URL=https://backoffice-production-d5cd.up.railway.app

# Supabase – server only (Server Actions, e.g. createOrder).
SUPABASE_SERVICE_ROLE_KEY=eyJ...
