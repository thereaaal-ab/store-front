# Supabase – same project as back office (Railway). Required for Vercel.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Where product images are served (backend uploads). Backend base URL only, no path.
# Examples: https://backoffice-production-d5cd.up.railway.app or http://localhost:3002
NEXT_PUBLIC_UPLOADS_BASE_URL=https://backoffice-production-d5cd.up.railway.app

# Supabase – server only (Server Actions, e.g. createOrder). Required for Vercel.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
